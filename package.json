{
  "name": "byk-pick-web-ui",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"pnpm run dev:client\" \"pnpm run dev:server\"",
    "dev:client": "vite --host 0.0.0.0",
    "dev:server": "cd server && node_modules/.bin/tsx src/index.ts",
    "build": "vite build --outDir server/dist/public && node scripts/build-server.mjs",
    "build:client": "vite build --outDir server/dist/public",
    "build:server": "node scripts/build-server.mjs",
    "start": "cd server && node dist/index.cjs",
    "pack": "cd server && pnpm pack"
  },
  "dependencies": {
    "vue": "^3.4.0",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^20.19.27",
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^10.0.3",
    "esbuild": "^0.24.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vue-tsc": "^1.8.0"
  }
}